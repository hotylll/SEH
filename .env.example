# 集思 · 信息收集整合系统 - 环境变量配置
# 复制此文件为 .env，填入你的密钥后使用

# ===== AI 分析（必填） =====
# OpenAI 兼容 API 的密钥
AI_API_KEY="your-api-key-here"

# API 地址（可选，默认 https://clip.ranai.cc.cd/v1）
# AI_API_BASE="https://clip.ranai.cc.cd/v1"

# 模型名称（可选，默认 z-ai/glm5.1）
# AI_MODEL="z-ai/glm5.1"

# ===== 搜索引擎（智能分析必填） =====
# SearXNG 实例地址
SEARXNG_URL="https://sh.ranai.de5.net"

# Exa MCP API Key（可选，配置后可增强搜索覆盖）
# EXA_API_KEY="your-exa-api-key"
